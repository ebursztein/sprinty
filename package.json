{
  "name": "sprinty-mcp",
  "version": "0.1.1",
  "description": "Disciplined sprint MCP for Claude Code, Codex, and Gemini",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Elie Bursztein",
  "homepage": "https://github.com/ebursztein/sprinty",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebursztein/sprinty.git"
  },
  "bugs": {
    "url": "https://github.com/ebursztein/sprinty/issues"
  },
  "bin": {
    "sprinty-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "clients"
  ],
  "scripts": {
    "build": "npm run build:dashboard && tsc -p tsconfig.json",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "svelte": "^4.2.20",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
