{
  "name": "sprinty-mcp",
  "version": "0.1.1",
  "description": "Disciplined sprint MCP for Claude Code, Codex, and Gemini",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Elie Bursztein",
  "homepage": "https://github.com/ebursztein/sprinty",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebursztein/sprinty.git"
  },
  "bugs": {
    "url": "https://github.com/ebursztein/sprinty/issues"
  },
  "bin": {
    "sprinty-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "clients"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
